  final Color cottonGold = const Color(0xFFC5A059);
  final Color crystalBlue = const Color(0xFF007BFF);

  // Centralized Data Store for this session
  final Map<String, List<ItemModel>> _categoryData = {
    "Cotton": [],
    "Cotton-Waste": [
      ItemModel(
        id: "1",
        name: "Cotton Flat Waste",
        category: "Cotton-Waste",
        status: "ACTIVE",
        description: "High quality flat waste for recycling.",
        attributes: [ItemAttribute(name: "Weight", unit: "KG")],
        createdAt: DateTime.now(),
      ),
    ],
    "Organic": [],
    "Region-Agri": [],
    "BCI": [],
  };

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      backgroundColor: const Color(0xFFF8FAFD),
      bottomNavigationBar: const CustomFooter(currentIndex: 1),
      appBar: _buildAppBar(),
      body: Column(
        crossAxisAlignment: CrossAxisAlignment.start,
        children: [
          _buildHeroHeader(),
          const SizedBox(height: 20),
          Padding(
            padding: const EdgeInsets.symmetric(horizontal: 25),
