  );

  Widget _staticTermsBlock() => Container(
    padding: const EdgeInsets.all(20),
    decoration: BoxDecoration(color: Colors.orange.withOpacity(0.05), borderRadius: BorderRadius.circular(15), border: Border.all(color: Colors.orange.withOpacity(0.1))),
    child: const Text(
      "• Material quality must match specified grade.\n"
      "• Payment timeline is strictly binding.\n"
      "• Brokerage is independent of mutual disputes.",
      style: TextStyle(fontSize: 11, color: Colors.brown, height: 1.8),
    ),
  );

  Widget _submitButton() => ElevatedButton(
    onPressed: () {
      if (_formKey.currentState!.validate() && _selectedSeller != null) {
        widget.onSave(SaudaModel(
          id: DateTime.now().millisecond.toString(),
          companyName: widget.companyName,
          saudaDate: DateTime.now(),
          spNo: "${widget.spPrefix}${DateTime.now().second}",
          seller: _selectedSeller!,
          buyer: _selectedBuyer ?? "N/A",
          item: _selectedItem ?? "N/A",
          subItem: _selectedSubItem,
          rate: double.tryParse(_rateC.text) ?? 0.0,
          qty: double.tryParse(_qtyC.text) ?? 0.0,
          tolerance: double.tryParse(_toleranceC.text) ?? 0.0,
          commSeller: double.tryParse(_commSellerC.text) ?? 0.0,
          commBuyer: double.tryParse(_commBuyerC.text) ?? 0.0,
          commConsignee: 0.0,
          remarks: _remarksC.text,
          transport: _transport,
          loading: _loading,
          insurance: _insurance,
          paymentTerm: _paymentTermC.text,
          transportBy: "Seller",
          inspection: "Buyer Place",
          tcRequired: _tcReq,
          tds: double.tryParse(_tdsC.text) ?? 0.1,
          tcs: 0.0,
          gstType: _gstType,
          gstRate: double.tryParse(_gstRateC.text) ?? 18.0,
          status: "BOOKED",
          createdAt: DateTime.now(),
        ));
        Navigator.pop(context);
        ScaffoldMessenger.of(context).showSnackBar(const SnackBar(content: Text("New Sauda Entry Saved Successfully!"), backgroundColor: Colors.blueAccent));
      }
    },
    style: ElevatedButton.styleFrom(backgroundColor: const Color(0xFF001A33), minimumSize: const Size(double.infinity, 65), shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(20))),
    child: const Text("FINALIZE & SAVE SAUDA", style: TextStyle(color: Colors.white, fontWeight: FontWeight.bold, letterSpacing: 1)),
  );
