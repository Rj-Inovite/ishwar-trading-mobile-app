  // ---------------------------------------------------------------------------
  // 5. VIEW & PDF LOGIC (COMMISSION BILLS & SIGNATURES)
  // ---------------------------------------------------------------------------
  void _handlePreview(SaudaModel sauda, {required bool isPdf}) {
    bool isCommissionUnlocked = DateTime.now().difference(sauda.createdAt).inDays >= 30;

    showModalBottomSheet(
      context: context,
      isScrollControlled: true,
      backgroundColor: Colors.transparent,
      builder: (context) => Container(
        height: MediaQuery.of(context).size.height * 0.9,
        decoration: const BoxDecoration(color: Colors.white, borderRadius: BorderRadius.vertical(top: Radius.circular(40))),
        child: Column(
          children: [
            _modalHeader(isPdf ? "OFFICIAL REPORT" : "SAUDA PREVIEW", isPdf),
            Expanded(
              child: SingleChildScrollView(
                padding: const EdgeInsets.all(30),
                child: Column(
                  crossAxisAlignment: CrossAxisAlignment.start,
                  children: [
                    _reportBrandHeader(sauda),
                    const Divider(height: 50),
                    _reportSection("CONTRACT PARTIES", [
                      "Seller: ${sauda.seller}",
                      "Buyer: ${sauda.buyer}",
                      if (sauda.consignee != null) "Consignee: ${sauda.consignee}",
                    ]),
                    _reportSection("PRODUCT SPECIFICATIONS", [
                      "Item: ${sauda.item} (${sauda.subItem ?? 'Standard'})",
                      "Quantity: ${sauda.qty} MT (±${sauda.tolerance}%)",
                      "Rate: ₹${sauda.rate} per MT",
                    ]),
                    _reportSection("FINANCIALS", [
                      "Base Amount: ₹${NumberFormat('#,###.00').format(sauda.baseAmount)}",
                      "GST (${sauda.gstRate}%): ₹${NumberFormat('#,###.00').format(sauda.gstAmount)}",
                      "Rounded Total: ₹${NumberFormat('#,###.00').format(sauda.roundedTotal)}",
                    ]),
                    if (isCommissionUnlocked) _reportSection("COMMISSION BILL (30-DAY STATUS)", [
                      "Seller Commission: ₹${sauda.commSeller * sauda.qty}",
                      "Buyer Commission: ₹${sauda.commBuyer * sauda.qty}",
                      "Invoice Status: GENERATED",
                    ]) else if (isPdf) const Text("* Commission details withheld (30-day term not met)", style: TextStyle(color: Colors.red, fontSize: 10, fontStyle: FontStyle.italic)),
                    const SizedBox(height: 60),
                    _signatureBlock(sauda.companyName),
                  ],
                ),
              ),
            ),
            if (isPdf) _downloadControlBar(),
          ],
        ),
      ),
    );
  }

